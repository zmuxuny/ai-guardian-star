// 备份日期：2026 年 3 月 17 日
// 备份说明：使用 SvgIcon 组件的版本，之后改用 Image 组件

import { mainPage } from "./mainpage"
import { person } from "./person"
import { record } from "./record"
import { ThemeManager, ThemeColors } from '../common/ThemeManager';
import { SvgIcon } from '../common/Icons';

/**
 * 底部导航布局组件 - 功能增强版
 */
@Builder
export function LayoutBuilder(): void {
  Layout()
}

interface TabItem {
  text: string
  icon: string
}

@Component
export struct Layout {
  // --- 状态管理 ---
  @State currentIndex: number = 0
  @State themeManager: ThemeManager = ThemeManager.getInstance();

  // 核心控制器
  private controller: TabsController = new TabsController();
  pathStack: NavPathStack = new NavPathStack();

  // 页签配置
  private tabData: TabItem[] = [
    { text: '主页', icon: 'home' },
    { text: '记录', icon: 'list' },
    { text: '个人', icon: 'user' },
  ]

  @Builder
  tabBuilder(index: number): void {
    Column() {
      // 使用 sizeType='nav' 自适应底部导航图标尺寸
      // 旧版：SvgIcon({ name: this.tabData[index].icon, color: ..., iconSize: 28 })
      SvgIcon({
        name: this.tabData[index].icon,
        color: this.currentIndex === index ? '#2563eb' : '#94a3b8',
        sizeType: 'nav'  // 新增：使用自适应尺寸，基准 32px，根据屏幕宽度在 27-37px 之间调整
      })

      Text(this.tabData[index].text)
        .fontSize(10).margin({ top: 4 })
        .fontColor(this.currentIndex === index ? '#2563eb' : '#94a3b8')
        .fontWeight(this.currentIndex === index ? FontWeight.Medium : FontWeight.Normal)

      if (this.currentIndex === index) {
        Circle({ width: 4, height: 4 })
          .fill('#2563eb')
          .margin({ top: 4 })
      }
    }
    .justifyContent(FlexAlign.Center)
    .alignItems(HorizontalAlign.Center)
    .width('100%').height('100%')
  }

  build() {
    NavDestination() {
      Tabs({
        barPosition: BarPosition.End,
        controller: this.controller,
        index: this.currentIndex
      }) {
        // Tab 0: 主页
        TabContent() {
          mainPage()
        }
        .tabBar(this.tabBuilder(0))

        // Tab 1: 记录
        TabContent() {
          record()
        }
        .tabBar(this.tabBuilder(1))

        // Tab 2: 个人
        TabContent() {
          person({ pathStack: this.pathStack })
        }
        .tabBar(this.tabBuilder(2))
      }
      .scrollable(true)
      .barMode(BarMode.Fixed)
      .onChange((index: number): void => {
        this.currentIndex = index
      })
      .barBackgroundColor(this.themeManager.colors.cardBackgroundColor)
      .backgroundColor(this.themeManager.colors.backgroundColor)
      .expandSafeArea([SafeAreaType.SYSTEM], [SafeAreaEdge.TOP, SafeAreaEdge.BOTTOM])
      .animationDuration(200)
    }
    .hideTitleBar(true)
    .onReady((context: NavDestinationContext): void => {
      this.pathStack = context.pathStack;
    })
  }
}
